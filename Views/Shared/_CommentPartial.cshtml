@model NoteTrackerApp.Helpers.CommentViewModel
@{
    var c = Model.Comment;
    var commentLike = Model.UserLikes.FirstOrDefault(l => l.CommentId == c.Id);
    var deleteController = Model.IsAdmin ? "Admin" : "Student";
    var likeController = Model.IsAdmin ? "Admin" : "Student";
}

<div class="mb-3" style="@(c.ParentCommentId != null ? "margin-left:2rem;border-left:2px solid rgba(99,102,241,0.2);padding-left:1rem;" : "")">
    <div class="glass-panel mb-1">
        <div class="d-flex align-items-start gap-2">
            @if (!string.IsNullOrEmpty(c.User.PhotoUrl))
            {
                <img src="@c.User.PhotoUrl" class="rounded-circle" width="34" height="34" style="object-fit:cover;flex-shrink:0;border:1px solid rgba(99,102,241,0.2);" />
            }
            else
            {
                <div style="width:34px;height:34px;border-radius:50%;background:rgba(99,102,241,0.12);display:flex;align-items:center;justify-content:center;color:#6366f1;flex-shrink:0;font-size:0.85rem;">
                    <i class="bi bi-person-fill"></i>
                </div>
            }
            <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <span class="fw-semibold" style="font-size:0.85rem;">@c.User.FullName</span>
                        <span class="text-muted ms-2" style="font-size:0.72rem;">@c.CreatedAt.ToString("dd MMM HH:mm")</span>
                    </div>
                    @if (Model.IsAdmin || c.UserId == Model.CurrentUserId)
                    {
                        <form asp-controller="@deleteController" asp-action="DeleteComment" method="post">
                            <input type="hidden" name="id" value="@c.Id" />
                            <button type="submit" class="glass-btn glass-btn-sm glass-btn-danger"
                                    onclick="return confirm('Bu yorumu silmek istiyor musunuz?')" style="padding:0.2em 0.6em;font-size:0.72rem;">
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        </form>
                    }
                </div>
                <p class="mb-1 mt-1" style="font-size:0.875rem;">@c.Content</p>

                @if (!string.IsNullOrEmpty(c.MediaUrl) && c.MediaType == "image")
                {
                    <img src="@c.MediaUrl" class="img-fluid rounded mb-1"
                         style="max-height:200px;cursor:pointer;border:1px solid rgba(255,255,255,0.07);"
                         onclick="document.getElementById('imgModal').style.display='flex';document.getElementById('imgModalSrc').src=this.src" />
                }

                <!-- Like/Dislike + Cevapla -->
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    <form asp-controller="@likeController" asp-action="LikeComment" method="post" class="d-inline">
                        <input type="hidden" name="commentId" value="@c.Id" />
                        <input type="hidden" name="postId" value="@Model.PostId" />
                        <input type="hidden" name="isLike" value="true" />
                        <button type="submit" class="glass-btn glass-btn-sm @(commentLike?.IsLike == true ? "glass-btn-success" : "")" style="padding:0.25em 0.65em;font-size:0.72rem;">
                            <i class="bi bi-hand-thumbs-up"></i> @c.Likes.Count(l => l.IsLike)
                        </button>
                    </form>
                    <form asp-controller="@likeController" asp-action="LikeComment" method="post" class="d-inline">
                        <input type="hidden" name="commentId" value="@c.Id" />
                        <input type="hidden" name="postId" value="@Model.PostId" />
                        <input type="hidden" name="isLike" value="false" />
                        <button type="submit" class="glass-btn glass-btn-sm @(commentLike?.IsLike == false ? "glass-btn-danger" : "")" style="padding:0.25em 0.65em;font-size:0.72rem;">
                            <i class="bi bi-hand-thumbs-down"></i> @c.Likes.Count(l => !l.IsLike)
                        </button>
                    </form>
                    <button type="button" class="glass-btn glass-btn-sm" style="padding:0.25em 0.65em;font-size:0.72rem;"
                            onclick="document.getElementById('reply-form-@c.Id').style.display = document.getElementById('reply-form-@c.Id').style.display === 'none' ? 'block' : 'none'">
                        <i class="bi bi-reply"></i> Cevapla
                    </button>
                </div>

                <!-- Reply Form -->
                <div id="reply-form-@c.Id" style="display:none;" class="mt-2">
                    <form asp-controller="@deleteController" asp-action="AddComment" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="postId" value="@Model.PostId" />
                        <input type="hidden" name="parentCommentId" value="@c.Id" />
                        <div class="d-flex gap-2">
                            <input type="text" name="content" class="form-control" placeholder="Cevabınızı yazın..." style="font-size:0.82rem;" />
                            <button type="submit" class="glass-btn glass-btn-sm"><i class="bi bi-send-fill"></i></button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Nested Replies -->
    @foreach (var reply in c.Replies.OrderBy(r => r.CreatedAt))
    {
        <partial name="_CommentPartial" model="@(new NoteTrackerApp.Helpers.CommentViewModel {
            Comment = reply, PostId = Model.PostId,
            CurrentUserId = Model.CurrentUserId,
            UserLikes = Model.UserLikes,
            IsAdmin = Model.IsAdmin })" />
    }
</div>
