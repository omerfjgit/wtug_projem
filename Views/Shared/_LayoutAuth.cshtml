<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - E-Kampüs</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        @@property --angle-1 { syntax: "<angle>"; inherits: false; initial-value: -75deg; }

        :root { --anim--hover-time:400ms; --anim--hover-ease:cubic-bezier(0.25,1,0.5,1); }

        * { box-sizing:border-box; }

        body {
            font-family:'Inter',sans-serif;
            margin:0; padding:0;
            min-height:100vh;
            display:flex; align-items:center; justify-content:center;
            overflow:hidden;
            background:#0a0f1e;
        }

        /* ── Background ── */
        .bg-image {
            position:fixed; inset:0; z-index:0;
        }
        .bg-image img {
            width:100%; height:100%; object-fit:cover;
            opacity:0.45;
            filter: blur(2px) brightness(0.7);
        }
        .bg-overlay {
            position:fixed; inset:0; z-index:1;
            background: linear-gradient(135deg,
                rgba(10,15,30,0.82) 0%,
                rgba(30,20,60,0.60) 50%,
                rgba(10,15,30,0.75) 100%);
        }

        /* ── Card ── */
        .login-card {
            position:relative; z-index:2;
            background:rgba(15,23,42,0.55);
            backdrop-filter:blur(28px); -webkit-backdrop-filter:blur(28px);
            border:1px solid rgba(255,255,255,0.12);
            border-radius:24px;
            box-shadow:0 32px 64px rgba(0,0,0,0.6), 0 0 0 1px rgba(255,255,255,0.04) inset;
            color:white;
            padding:2.75rem 2.5rem;
            width:100%; max-width:440px;
            animation:slideUp 0.7s cubic-bezier(0.22,1,0.36,1);
        }
        @@keyframes slideUp {
            from { opacity:0; transform:translateY(30px) scale(0.97); }
            to   { opacity:1; transform:translateY(0) scale(1); }
        }

        /* ── Inputs ── */
        .form-control {
            background:rgba(255,255,255,0.06);
            border:1px solid rgba(255,255,255,0.12);
            color:white; border-radius:12px;
            padding:0.7rem 1rem;
            letter-spacing: 0.5px;
            transition:all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .form-control:focus {
            background:rgba(255,255,255,0.1);
            border-color:#6366f1;
            color:white;
            box-shadow:0 0 0 3px rgba(99,102,241,0.25);
            letter-spacing: 1.5px;
            text-shadow: 0 0 8px rgba(99,102,241,0.6);
        }
        .form-control::placeholder { color:rgba(255,255,255,0.3); }
        .input-group-text {
            background:rgba(255,255,255,0.06);
            border:1px solid rgba(255,255,255,0.12);
            color:#6366f1; border-radius:12px 0 0 12px;
        }
        .input-group .form-control { border-radius:0 12px 12px 0; }

        /* ── Glass Button ── */
        .glass-btn {
            all:unset; cursor:pointer; position:relative;
            pointer-events:auto; z-index:3;
            display:inline-flex; align-items:center; justify-content:center; gap:0.45em;
            background:linear-gradient(-75deg,rgba(255,255,255,0.05),rgba(255,255,255,0.22),rgba(255,255,255,0.05));
            border-radius:999vw;
            box-shadow: inset 0 0.125em 0.125em rgba(0,0,0,0.06),
                        inset 0 -0.125em 0.125em rgba(255,255,255,0.35),
                        0 0.25em 0.125em -0.125em rgba(0,0,0,0.3),
                        0 0 0.1em 0.25em inset rgba(255,255,255,0.12);
            backdrop-filter:blur(4px);
            transition:all var(--anim--hover-time) var(--anim--hover-ease);
            padding:0.7em 2em;
            font-family:'Inter',sans-serif; font-weight:600; font-size:1rem;
            letter-spacing:-0.01em; color:#f1f5f9;
            text-shadow:0 1px 3px rgba(0,0,0,0.3);
            border:none; text-decoration:none; width:100%;
        }
        .glass-btn:hover { transform:scale(0.98); color:#fff; }
        .glass-btn::after {
            content:""; position:absolute; z-index:1; inset:0; border-radius:999vw;
            width:calc(100% + 1px); height:calc(100% + 1px); top:-0.5px; left:-0.5px;
            padding:1px; box-sizing:border-box;
            background:conic-gradient(from var(--angle-1) at 50% 50%,rgba(255,255,255,0.4),rgba(255,255,255,0.05) 5% 40%,rgba(255,255,255,0.4) 50%,rgba(255,255,255,0.05) 60% 95%,rgba(255,255,255,0.4)),
                       linear-gradient(180deg,rgba(255,255,255,0.3),rgba(255,255,255,0.1));
            mask:linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask-composite:exclude;
            transition:all var(--anim--hover-time) var(--anim--hover-ease), --angle-1 500ms ease;
        }
        .glass-btn:hover::after { --angle-1:-125deg; }
        .glass-btn:active { transform:scale(0.96); }
        /* ── Full-width login button ── */
        .glass-btn-login {
            display: block;
            width: 100%;
            box-sizing: border-box;
            cursor: pointer; position: relative;
            background: linear-gradient(-75deg, rgba(255,255,255,0.05), rgba(255,255,255,0.22), rgba(255,255,255,0.05));
            border-radius: 14px;
            box-shadow: inset 0 0.125em 0.125em rgba(0,0,0,0.06),
                        inset 0 -0.125em 0.125em rgba(255,255,255,0.35),
                        0 0.25em 0.125em -0.125em rgba(0,0,0,0.3),
                        0 0 0.1em 0.25em inset rgba(255,255,255,0.12);
            backdrop-filter: blur(4px);
            transition: all 0.3s ease;
            padding: 0.85em 2em;
            font-family: 'Inter', sans-serif; font-weight: 700; font-size: 1rem;
            letter-spacing: 0.01em; color: #f1f5f9;
            text-shadow: 0 1px 3px rgba(0,0,0,0.3);
            border: none; text-align: center;
        }
        .glass-btn-login:hover { transform: translateY(-1px); opacity: 0.92; color: #fff; }
        .glass-btn-login:active { transform: translateY(0) scale(0.99); }
        .glass-btn-login::after {
            content: ""; position: absolute; z-index: 1; inset: 0; border-radius: 14px;
            width: calc(100% + 1px); height: calc(100% + 1px); top: -0.5px; left: -0.5px;
            padding: 1px; box-sizing: border-box;
            background: linear-gradient(180deg, rgba(255,255,255,0.35), rgba(255,255,255,0.08));
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask-composite: exclude;
        }
    </style>
</head>
<body>
    <div class="bg-image">
        <img src="/images/login-bg.jpg" alt="Eğitim" />
    </div>
    <div class="bg-overlay"></div>

    <div class="login-card">
        @RenderBody()
    </div>
</body>
</html>
