<!DOCTYPE html>
<html lang="tr" data-bs-theme="dark">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Yönetim Paneli</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <style>
        @@property --angle-1 { syntax: "<angle>"; inherits: false; initial-value: -75deg; }
        @@property --angle-2 { syntax: "<angle>"; inherits: false; initial-value: -45deg; }

        :root {
            --anim--hover-time: 400ms;
            --anim--hover-ease: cubic-bezier(0.25,1,0.5,1);
            --glass-bg-light: rgba(255,255,255,0.55);
            --glass-bg-dark: rgba(15,23,42,0.65);
            --glass-border-light: rgba(255,255,255,0.7);
            --glass-border-dark: rgba(255,255,255,0.08);
            --sidebar-width: 260px;
            --topbar-h: 68px;
            --accent: #6366f1;
            --accent2: #38bdf8;
        }

        /* ── Base ── */
        body {
            font-family:'Inter',sans-serif;
            margin:0; min-height:100vh; display:flex;
            background: #0f172a;
            background-image: radial-gradient(ellipse at 20% 50%, rgba(99,102,241,0.15) 0%, transparent 60%),
                              radial-gradient(ellipse at 80% 10%, rgba(56,189,248,0.1) 0%, transparent 55%);
            color:#f1f5f9;
            transition: background 0.3s;
        }
        [data-bs-theme="light"] body, body[data-bs-theme="light"] {
            background: #f0f4ff;
            background-image: radial-gradient(ellipse at 20% 50%, rgba(99,102,241,0.08) 0%, transparent 60%),
                              radial-gradient(ellipse at 80% 10%, rgba(56,189,248,0.06) 0%, transparent 55%);
            color:#1e293b;
        }

        /* ── Sidebar ── */
        .sidebar {
            width: var(--sidebar-width);
            min-height: 100vh;
            position: fixed; top:0; left:0; z-index:1000;
            background: rgba(15,23,42,0.8);
            backdrop-filter: blur(24px);
            -webkit-backdrop-filter: blur(24px);
            border-right: 1px solid rgba(255,255,255,0.07);
            display:flex; flex-direction:column;
            padding: 1.5rem 0 1rem;
            transition: all 0.3s;
        }
        [data-bs-theme="light"] .sidebar {
            background: rgba(255,255,255,0.75);
            border-right: 1px solid rgba(99,102,241,0.15);
        }
        .sidebar-logo {
            display:flex; align-items:center; gap:12px;
            padding: 0 1.25rem 1.5rem;
            border-bottom: 1px solid rgba(255,255,255,0.07);
            margin-bottom: 0.75rem;
        }
        [data-bs-theme="light"] .sidebar-logo { border-bottom-color: rgba(99,102,241,0.1); }
        .logo-icon {
            width:42px; height:42px; border-radius:12px;
            background: linear-gradient(135deg, #6366f1, #38bdf8);
            display:flex; align-items:center; justify-content:center;
            color:white; font-size:1.2rem;
            box-shadow: 0 4px 16px rgba(99,102,241,0.4);
        }
        .logo-text h5 { margin:0; font-weight:700; font-size:1rem; color:#f1f5f9; }
        [data-bs-theme="light"] .logo-text h5 { color:#1e293b; }
        .logo-text small { color:#94a3b8; font-size:0.72rem; }

        .nav-section-label {
            font-size:0.65rem; font-weight:700; letter-spacing:0.12em;
            color:#475569; text-transform:uppercase;
            padding: 0.75rem 1.25rem 0.25rem;
        }
        .sidebar-nav a {
            display:flex; align-items:center; gap:10px;
            padding: 0.7rem 1.25rem; margin: 2px 0.75rem;
            border-radius:10px; text-decoration:none;
            color:#94a3b8; font-size:0.875rem; font-weight:500;
            transition: all 0.2s;
        }
        .sidebar-nav a i { font-size:1.05rem; width:20px; text-align:center; }
        .sidebar-nav a:hover { background:rgba(99,102,241,0.12); color:#a5b4fc; }
        .sidebar-nav a.active { background:rgba(99,102,241,0.2); color:#c7d2fe; border-left: 3px solid #6366f1; }
        [data-bs-theme="light"] .sidebar-nav a { color:#475569; }
        [data-bs-theme="light"] .sidebar-nav a:hover { background:rgba(99,102,241,0.08); color:#4338ca; }
        [data-bs-theme="light"] .sidebar-nav a.active { background:rgba(99,102,241,0.12); color:#4338ca; }

        /* ── Main ── */
        .main-wrapper { margin-left: var(--sidebar-width); flex:1; display:flex; flex-direction:column; min-height:100vh; }

        /* ── Topbar ── */
        .topbar {
            height: var(--topbar-h);
            background: rgba(15,23,42,0.6);
            backdrop-filter: blur(20px);
            -webkit-backdrop-filter: blur(20px);
            border-bottom: 1px solid rgba(255,255,255,0.06);
            display:flex; align-items:center; justify-content:space-between;
            padding: 0 2rem;
            position: sticky; top:0; z-index:900;
        }
        [data-bs-theme="light"] .topbar {
            background: rgba(255,255,255,0.7);
            border-bottom: 1px solid rgba(99,102,241,0.1);
        }
        .topbar-title { font-weight:700; font-size:1.1rem; color:#f1f5f9; }
        [data-bs-theme="light"] .topbar-title { color:#1e293b; }

        .content-area { padding:2rem; flex:1; }

        /* ── Glass Card ── */
        .glass-card {
            background: rgba(30,41,59,0.6);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.07);
            border-radius:16px;
            padding:1.5rem;
            transition: all 0.3s;
        }
        [data-bs-theme="light"] .glass-card {
            background: rgba(255,255,255,0.7);
            border: 1px solid rgba(99,102,241,0.12);
            box-shadow: 0 4px 24px rgba(99,102,241,0.08);
        }
        .glass-panel {
            background: rgba(15,23,42,0.4);
            backdrop-filter: blur(12px);
            border: 1px solid rgba(255,255,255,0.05);
            border-radius:12px; padding:1.25rem;
        }
        [data-bs-theme="light"] .glass-panel {
            background: rgba(248,250,255,0.8);
            border: 1px solid rgba(99,102,241,0.1);
        }

        /* ── Table ── */
        .table { color: inherit; }
        .table th { font-size:0.75rem; font-weight:600; letter-spacing:0.05em; text-transform:uppercase; color:#64748b; border-bottom-color:rgba(255,255,255,0.07); }
        [data-bs-theme="light"] .table th { border-bottom-color:rgba(99,102,241,0.1); }
        .table td { border-color:rgba(255,255,255,0.04); vertical-align:middle; }
        [data-bs-theme="light"] .table td { border-color:rgba(0,0,0,0.05); }
        .table-hover tbody tr:hover { background:rgba(99,102,241,0.07); }

        /* ── Form Controls ── */
        .form-control, .form-select {
            background: rgba(30,41,59,0.5);
            border: 1px solid rgba(255,255,255,0.1);
            color:#f1f5f9; border-radius:10px;
            transition: all 0.2s;
        }
        .form-control:focus, .form-select:focus {
            background: rgba(30,41,59,0.7);
            border-color: #6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.2);
            color:#f1f5f9;
        }
        [data-bs-theme="light"] .form-control, [data-bs-theme="light"] .form-select {
            background: rgba(255,255,255,0.8);
            border-color: rgba(99,102,241,0.2);
            color:#1e293b;
        }
        [data-bs-theme="light"] .form-control:focus, [data-bs-theme="light"] .form-select:focus {
            background: #fff;
            border-color:#6366f1;
            box-shadow: 0 0 0 3px rgba(99,102,241,0.15);
            color:#1e293b;
        }
        .form-label { font-size:0.8rem; font-weight:600; color:#94a3b8; margin-bottom:0.4rem; }
        [data-bs-theme="light"] .form-label { color:#475569; }
        ::placeholder { color:#475569 !important; }

        /* ── Badge / Badge-glass ── */
        .badge-glass {
            background: rgba(99,102,241,0.15);
            color:#a5b4fc;
            border: 1px solid rgba(99,102,241,0.25);
            border-radius:6px; padding:3px 10px;
            font-size:0.72rem; font-weight:600;
        }

        /* ════════════════════════════
           PREMIUM GLASS BUTTON
        ════════════════════════════ */
        .btn-wrap {
            position:relative; z-index:2; border-radius:999vw;
            background:transparent; pointer-events:none;
            transition:all var(--anim--hover-time) var(--anim--hover-ease);
            display:inline-block;
        }
        .btn-wrap .btn-shadow {
            --sc:2em;
            position:absolute;
            width:calc(100% + var(--sc)); height:calc(100% + var(--sc));
            top:calc(0% - var(--sc)/2); left:calc(0% - var(--sc)/2);
            filter:blur(4px); overflow:visible; pointer-events:none;
        }
        .btn-wrap .btn-shadow::after {
            content:""; position:absolute; z-index:0; inset:0; border-radius:999vw;
            background:linear-gradient(180deg,rgba(0,0,0,0.2),rgba(0,0,0,0.1));
            width:calc(100% - var(--sc) - 0.25em); height:calc(100% - var(--sc) - 0.25em);
            top:calc(var(--sc) - 0.5em); left:calc(var(--sc) - 0.875em);
            padding:0.125em; box-sizing:border-box;
            mask:linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask-composite:exclude;
            transition:all var(--anim--hover-time) var(--anim--hover-ease);
        }
        .glass-btn {
            all:unset; cursor:pointer; position:relative;
            pointer-events:auto; z-index:3;
            display:inline-flex; align-items:center; justify-content:center; gap:0.45em;
            background:linear-gradient(-75deg,rgba(255,255,255,0.05),rgba(255,255,255,0.22),rgba(255,255,255,0.05));
            border-radius:999vw;
            box-shadow: inset 0 0.125em 0.125em rgba(0,0,0,0.06),
                        inset 0 -0.125em 0.125em rgba(255,255,255,0.4),
                        0 0.25em 0.125em -0.125em rgba(0,0,0,0.25),
                        0 0 0.1em 0.25em inset rgba(255,255,255,0.15);
            backdrop-filter:blur(4px);
            transition:all var(--anim--hover-time) var(--anim--hover-ease);
            padding:0.55em 1.3em;
            font-family:'Inter',sans-serif; font-weight:600; font-size:0.875rem;
            letter-spacing:-0.02em;
            color:#f1f5f9;
            text-shadow:0 0.25em 0.05em rgba(0,0,0,0.2);
            border:none; text-decoration:none;
            white-space:nowrap;
        }
        [data-bs-theme="light"] .glass-btn {
            color:rgba(30,30,50,1);
            box-shadow: inset 0 0.125em 0.125em rgba(0,0,0,0.04),
                        inset 0 -0.125em 0.125em rgba(255,255,255,0.7),
                        0 0.25em 0.125em -0.125em rgba(0,0,0,0.12),
                        0 0 0.1em 0.25em inset rgba(255,255,255,0.5);
            text-shadow:0 0.1em 0.05em rgba(0,0,0,0.08);
        }
        .glass-btn:hover {
            transform:scale(0.975); color:inherit; text-decoration:none;
            box-shadow: inset 0 0.125em 0.125em rgba(0,0,0,0.05),
                        inset 0 -0.125em 0.125em rgba(255,255,255,0.5),
                        0 0.15em 0.05em -0.1em rgba(0,0,0,0.3),
                        0 0 0.05em 0.1em inset rgba(255,255,255,0.4);
        }
        .glass-btn::after {
            content:""; position:absolute; z-index:1; inset:0; border-radius:999vw;
            width:calc(100% + 1px); height:calc(100% + 1px); top:-0.5px; left:-0.5px;
            padding:1px; box-sizing:border-box;
            background:conic-gradient(from var(--angle-1) at 50% 50%,rgba(0,0,0,0.5),rgba(0,0,0,0) 5% 40%,rgba(0,0,0,0.5) 50%,rgba(0,0,0,0) 60% 95%,rgba(0,0,0,0.5)),
                       linear-gradient(180deg,rgba(255,255,255,0.5),rgba(255,255,255,0.5));
            mask:linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask-composite:exclude;
            transition:all var(--anim--hover-time) var(--anim--hover-ease), --angle-1 500ms ease;
        }
        .glass-btn:hover::after { --angle-1:-125deg; }
        .glass-btn:active { transform:scale(0.96) rotate3d(1,0,0,15deg); }
        .glass-btn:active::after { --angle-1:-75deg; }

        /* Renk varyantları */
        .glass-btn-danger { color:#fca5a5 !important; }
        .glass-btn-success { color:#86efac !important; }
        .glass-btn-info { color:#7dd3fc !important; }
        [data-bs-theme="light"] .glass-btn-danger { color:#dc2626 !important; }
        [data-bs-theme="light"] .glass-btn-success { color:#16a34a !important; }
        [data-bs-theme="light"] .glass-btn-info { color:#0284c7 !important; }

        /* ── Theme Toggle ── */
        .theme-toggle {
            cursor:pointer; padding:8px; border-radius:50%;
            background:transparent; border: 1px solid rgba(255,255,255,0.1);
            color:#94a3b8; transition:all 0.3s; font-size:1rem;
        }
        .theme-toggle:hover { background:rgba(99,102,241,0.15); color:#a5b4fc; }
        [data-bs-theme="light"] .theme-toggle { border-color:rgba(99,102,241,0.2); color:#475569; }
        [data-bs-theme="light"] .theme-toggle:hover { background:rgba(99,102,241,0.08); color:#4338ca; }

        /* ── Modal glass ── */
        .modal-glass .modal-content {
            background: rgba(15,23,42,0.85);
            backdrop-filter:blur(24px);
            border:1px solid rgba(255,255,255,0.08);
            border-radius:16px; color:white;
        }
        [data-bs-theme="light"] .modal-glass .modal-content {
            background: rgba(255,255,255,0.9);
            border-color:rgba(99,102,241,0.15);
            color:#1e293b;
        }
        .modal-glass .modal-header { border-bottom:1px solid rgba(255,255,255,0.07); }
        .modal-glass .modal-footer { border-top:1px solid rgba(255,255,255,0.07); }
        [data-bs-theme="light"] .modal-glass .modal-header { border-bottom-color:rgba(99,102,241,0.1); }
        [data-bs-theme="light"] .modal-glass .modal-footer { border-top-color:rgba(99,102,241,0.1); }

        /* ── Search Box ── */
        .search-box { position:relative; }
        .search-box i { position:absolute; left:12px; top:50%; transform:translateY(-50%); color:#64748b; }
        .search-box input { padding-left:36px; }

        /* ── Scrollbar ── */
        ::-webkit-scrollbar { width:6px; }
        ::-webkit-scrollbar-track { background:transparent; }
        ::-webkit-scrollbar-thumb { background:rgba(99,102,241,0.3); border-radius:3px; }
        .glass-btn-login {
            display: block; width: 100%; box-sizing: border-box; cursor: pointer; position: relative;
            background: linear-gradient(-75deg, rgba(255,255,255,0.05), rgba(255,255,255,0.22), rgba(255,255,255,0.05));
            border-radius: 12px;
            box-shadow: inset 0 0.125em 0.125em rgba(0,0,0,0.06), inset 0 -0.125em 0.125em rgba(255,255,255,0.4),
                        0 0.25em 0.125em -0.125em rgba(0,0,0,0.25), 0 0 0.1em 0.25em inset rgba(255,255,255,0.15);
            backdrop-filter: blur(4px); transition: all 0.3s ease; padding: 0.75em 1.5em;
            font-family: 'Inter', sans-serif; font-weight: 600; font-size: 1rem;
            color: #f1f5f9; text-shadow: 0 0.25em 0.05em rgba(0,0,0,0.2); border: none; text-align: center;
        }
        .glass-btn-login:hover { transform: scale(0.985); color: #fff; }
        .glass-btn-login::after {
            content: ""; position: absolute; z-index: 1; inset: 0; border-radius: 12px;
            width: calc(100% + 1px); height: calc(100% + 1px); top: -0.5px; left: -0.5px;
            padding: 1px; box-sizing: border-box;
            background: linear-gradient(180deg, rgba(255,255,255,0.5), rgba(255,255,255,0.2));
            mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
            mask-composite: exclude;
        }
        /* ── Badge glass ── */
        .badge-glass {
            background: rgba(99, 102, 241, 0.1);
            color: #a5b4fc;
            border: 1px solid rgba(99, 102, 241, 0.2);
            border-radius: 6px;
            padding: 2px 8px;
            font-size: 0.75rem;
            font-weight: 600;
            display: inline-flex;
            align-items: center;
        }
        [data-bs-theme="light"] .badge-glass { background:rgba(99,102,241,0.08); color:#4338ca; border-color:rgba(99,102,241,0.15); }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <nav class="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon"><i class="bi bi-shield-lock-fill"></i></div>
            <div class="logo-text">
                <h5>E-Kampüs</h5>
                <small>Yönetim Paneli</small>
            </div>
        </div>

        <div class="nav-section-label">Ana Menü</div>
        <div class="sidebar-nav">
            <a asp-controller="Admin" asp-action="Index"
               class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Index" && ViewContext.RouteData.Values["Controller"]?.ToString() == "Admin" ? "active" : "")">
                <i class="bi bi-speedometer2"></i><span>Dashboard</span>
            </a>
            <a asp-controller="Admin" asp-action="Students"
               class="@(ViewContext.RouteData.Values["Action"]?.ToString()?.Contains("Student") == true ? "active" : "")">
                <i class="bi bi-people-fill"></i><span>Öğrenciler</span>
            </a>
            <a asp-controller="Admin" asp-action="Grades"
               class="@(ViewContext.RouteData.Values["Action"]?.ToString()?.Contains("Grade") == true ? "active" : "")">
                <i class="bi bi-journal-check"></i><span>Not Girişi</span>
            </a>
            <a asp-controller="Admin" asp-action="PerformanceCriteria"
               class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "PerformanceCriteria" ? "active" : "")">
                <i class="bi bi-bar-chart-steps"></i><span>Performans Takibi</span>
            </a>
            <a asp-controller="Admin" asp-action="ProjectAssignments"
               class="@(ViewContext.RouteData.Values["Action"]?.ToString()?.Contains("Project") == true ? "active" : "")">
                <i class="bi bi-folder2-open"></i><span>Proje Ödevleri</span>
            </a>
        </div>

        <div class="nav-section-label">İletişim</div>
        <div class="sidebar-nav">
            <a asp-controller="Admin" asp-action="Announcements"
               class="@(ViewContext.RouteData.Values["Action"]?.ToString()?.Contains("Announcement") == true ? "active" : "")">
                <i class="bi bi-megaphone-fill"></i><span>Duyurular</span>
            </a>
            <a asp-controller="Admin" asp-action="Discussions"
               class="@(ViewContext.RouteData.Values["Action"]?.ToString()?.Contains("Discussion") == true || ViewContext.RouteData.Values["Action"]?.ToString()?.Contains("Post") == true ? "active" : "")">
                <i class="bi bi-chat-square-text-fill"></i><span>Tartışmalar</span>
            </a>
            <a asp-controller="Calendar" asp-action="Index"
               class="@(ViewContext.RouteData.Values["Controller"]?.ToString() == "Calendar" ? "active" : "")">
                <i class="bi bi-calendar3"></i><span>Takvim</span>
            </a>
        </div>

        <div class="nav-section-label">Hesap</div>
        <div class="sidebar-nav">
            <a asp-controller="Admin" asp-action="Profile"
               class="@(ViewContext.RouteData.Values["Action"]?.ToString() == "Profile" ? "active" : "")">
                <i class="bi bi-person-gear"></i><span>Profil</span>
            </a>
            <a asp-controller="Auth" asp-action="Logout" style="color:#f87171 !important;">
                <i class="bi bi-box-arrow-left"></i><span>Çıkış Yap</span>
            </a>
        </div>
    </nav>

    <!-- Main -->
    <div class="main-wrapper">
        <div class="topbar">
            <span class="topbar-title">@ViewData["Title"]</span>
            <div class="d-flex align-items-center gap-3">
                <button class="theme-toggle" onclick="toggleTheme()" title="Tema Değiştir">
                    <i class="bi bi-moon-fill" id="themeIcon"></i>
                </button>
                <div style="font-size:0.85rem; color:#94a3b8;">
                    <i class="bi bi-person-circle me-1"></i>@User.Identity.Name
                    <span class="badge-glass ms-1">Admin</span>
                </div>
            </div>
        </div>

        <div class="content-area">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show mb-3" style="background:rgba(16,185,129,0.15);border:1px solid rgba(16,185,129,0.3);color:#86efac;border-radius:12px;">
                    <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert"></button>
                </div>
            }
            @RenderBody()
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        function toggleTheme() {
            const html = document.documentElement;
            const cur = html.getAttribute('data-bs-theme');
            const next = cur === 'dark' ? 'light' : 'dark';
            html.setAttribute('data-bs-theme', next);
            localStorage.setItem('theme', next);
            updateThemeIcon(next);
        }
        function updateThemeIcon(t) {
            const i = document.getElementById('themeIcon');
            if (!i) return;
            i.className = t === 'dark' ? 'bi bi-sun-fill text-warning' : 'bi bi-moon-fill';
        }
        document.addEventListener('DOMContentLoaded', () => {
            const saved = localStorage.getItem('theme') || 'dark';
            document.documentElement.setAttribute('data-bs-theme', saved);
            updateThemeIcon(saved);
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
