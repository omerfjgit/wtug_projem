@model NoteTrackerApp.Models.Student

@{
    ViewData["Title"] = "Öğrenci Profili";
    Layout = "_LayoutStudent";
}

<div class="row g-4">
    <!-- Profil & Bilgiler -->
    <div class="col-md-4">
        <div class="glass-card text-center h-100 d-flex flex-column align-items-center justify-content-center py-5">
            <div class="position-relative mb-4">
                @if (string.IsNullOrEmpty(Model.User.PhotoUrl))
                {
                    <div style="width: 120px; height: 120px; border-radius: 50%; background: var(--primary-gradient); display: flex; align-items: center; justify-content: center; color: white; font-size: 3rem; margin: 0 auto; box-shadow: 0 10px 25px rgba(99, 102, 241, 0.4);">
                        @Model.User.FullName.Substring(0, 1).ToUpper()
                    </div>
                }
                else
                {
                    <img src="@Model.User.PhotoUrl" alt="Profil Fotoğrafı" style="width: 120px; height: 120px; border-radius: 50%; object-fit: cover; box-shadow: 0 10px 25px rgba(0,0,0,0.2); border: 4px solid var(--card-bg);" />
                }
                
                @if (Model.User.CanChangePhoto)
                {
                    <button type="button" class="btn btn-sm btn-primary rounded-circle position-absolute" style="bottom: 0; right: 0; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 10px rgba(0,0,0,0.2);" data-bs-toggle="modal" data-bs-target="#photoModal">
                        <i class="bi bi-camera-fill"></i>
                    </button>
                }
            </div>

            <h4 class="fw-bold mb-1">@Model.User.FullName</h4>
            <p class="text-muted mb-4">@Model.ClassSection Sınıfı Öğrencisi</p>

            <div class="w-100 px-4">
                <div class="d-flex justify-content-between border-bottom border-secondary pb-2 mb-2" style="opacity: 0.7;">
                    <span class="small fw-bold">Okul No</span>
                    <span class="small fw-bold text-primary">@Model.StudentNumber</span>
                </div>
                <div class="d-flex justify-content-between pb-2" style="opacity: 0.7;">
                    <span class="small fw-bold">Kayıt Tarihi</span>
                    <span class="small fw-bold text-primary">@Model.RegisteredAt.ToString("dd MMM yyyy")</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Notlar Tablosu -->
    <div class="col-md-8">
        <div class="glass-card h-100">
            <div class="d-flex justify-content-between align-items-center mb-4">
                <h5 class="fw-bold m-0"><i class="bi bi-journal-check text-success me-2"></i> Dönem Notları</h5>
                @if (Model.Grades != null && Model.Grades.Any())
                {
                    var totalAvg = Model.Grades.Average(g => g.Average);
                    <span class="badge" style="background: rgba(16,185,129,0.15); color: #86efac; border: 1px solid rgba(16,185,129,0.3); font-size: 0.9rem; padding: 6px 12px;">
                        Genel Ortalama: @totalAvg.ToString("0.00")
                    </span>
                }
            </div>
            
            @if (Model.Grades != null && Model.Grades.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle" style="color: var(--text-color);">
                        <thead style="background-color: var(--table-light-bg);">
                            <tr>
                                <th>Ders Adı</th>
                                <th>Dönem</th>
                                <th>1. Sınav</th>
                                <th>2. Sınav</th>
                                <th>Sözlü 1</th>
                                <th>Sözlü 2</th>
                                <th>Performans</th>
                                <th>Proje</th>
                                <th>Ortalama</th>
                                <th>Sınıf Ort.</th>
                                <th>Durum</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var grade in Model.Grades.OrderByDescending(g => g.CreatedAt))
                            {
                                <tr>
                                    <td class="fw-bold">@grade.CourseName</td>
                                    <td><span class="badge bg-secondary">@grade.Semester</span></td>
                                    <td>@grade.Exam1</td>
                                    <td>@grade.Exam2</td>
                                    <td>@grade.Oral1</td>
                                    <td>@grade.Oral2</td>
                                    <td>@grade.Performance1</td>
                                    <td>@grade.Project</td>
                                    <td class="fw-bold @(grade.Average >= 50 ? "text-success" : "text-danger")">
                                        @grade.Average.ToString("0.00")
                                    </td>
                                    @{
                                        var averages = ViewBag.ClassAverages as Dictionary<string, double>;
                                        double classAvg = 0;
                                        if(averages != null && averages.ContainsKey(grade.CourseName)) {
                                            classAvg = averages[grade.CourseName];
                                        }
                                    }
                                    <td class="fw-bold text-info">
                                        @(classAvg > 0 ? classAvg.ToString("0.00") : "-")
                                    </td>
                                    <td>
                                        @if (grade.IsPassed)
                                        {
                                            <span class="badge bg-success">Geçti</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Kaldı</span>
                                        }
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-5">
                    <i class="bi bi-folder2-open fs-1 d-block mb-3"></i>
                    Henüz not girişi yapılmamış.
                </div>
            }
        </div>
    </div>

    <!-- Projeler Tablosu -->
    <div class="col-md-12">
        <div class="glass-card">
            <h5 class="fw-bold mb-4"><i class="bi bi-folder2-open text-warning me-2"></i> Proje Ödevlerim</h5>
            
            @{
                var projects = ViewBag.Projects as List<NoteTrackerApp.Models.ProjectAssignment>;
            }
            
            @if (projects != null && projects.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle" style="color: var(--text-color);">
                        <thead style="background-color: var(--table-light-bg);">
                            <tr>
                                <th>Ders Adı</th>
                                <th>Proje Konusu</th>
                                <th>Durum</th>
                                <th>Taslak Teslim</th>
                                <th>Ara Kontrol</th>
                                <th>Nihai Teslim</th>
                                <th>Öğretmen Notu</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var proj in projects)
                            {
                                <tr>
                                    <td class="fw-bold">@proj.CourseName</td>
                                    <td>@proj.Topic</td>
                                    <td>
                                        @{
                                            var badgeClass = proj.Status switch {
                                                NoteTrackerApp.Models.ProjectStatus.Atandı => "bg-secondary",
                                                NoteTrackerApp.Models.ProjectStatus.Taslak => "bg-info text-dark",
                                                NoteTrackerApp.Models.ProjectStatus.AraKontrol => "bg-warning text-dark",
                                                NoteTrackerApp.Models.ProjectStatus.NihaiFazı => "bg-primary",
                                                NoteTrackerApp.Models.ProjectStatus.Teslim => "bg-success",
                                                _ => "bg-secondary"
                                            };
                                        }
                                        <span class="badge @badgeClass">@proj.Status</span>
                                    </td>
                                    <td>@(proj.DraftDueDate?.ToString("dd MMM yyyy") ?? "-")</td>
                                    <td>@(proj.CheckDate?.ToString("dd MMM yyyy") ?? "-")</td>
                                    <td>@(proj.FinalDueDate?.ToString("dd MMM yyyy") ?? "-")</td>
                                    <td class="small text-muted" style="max-width:200px; white-space:nowrap; overflow:hidden; text-overflow:ellipsis;" title="@proj.TeacherNote">
                                        @(string.IsNullOrEmpty(proj.TeacherNote) ? "-" : proj.TeacherNote)
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="text-center text-muted py-4">
                    <i class="bi bi-folder-x fs-2 d-block mb-2"></i>
                    Atanmış bir proje ödeviniz bulunmuyor.
                </div>
            }
        </div>
    </div>
</div>

<!-- Photo Upload Modal -->
@if (Model.User.CanChangePhoto)
{
    <div class="modal fade" id="photoModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content" style="
                background: rgba(15,23,42,0.92);
                backdrop-filter: blur(28px);
                -webkit-backdrop-filter: blur(28px);
                border: 1px solid rgba(255,255,255,0.1);
                border-radius: 20px;
                color: white;
                box-shadow: 0 32px 64px rgba(0,0,0,0.5);
            ">
                <div class="modal-header" style="border-bottom: 1px solid rgba(255,255,255,0.08); padding: 1.25rem 1.5rem;">
                    <div class="d-flex align-items-center gap-2">
                        <div style="width:36px;height:36px;border-radius:10px;background:rgba(99,102,241,0.2);display:flex;align-items:center;justify-content:center;color:#a5b4fc;">
                            <i class="bi bi-camera-fill"></i>
                        </div>
                        <h5 class="modal-title fw-bold m-0">Profil Fotoğrafını Değiştir</h5>
                    </div>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <form asp-action="UploadPhoto" method="post" enctype="multipart/form-data">
                    <div class="modal-body" style="padding: 1.5rem;">
                        <p class="text-muted small mb-3">
                            <i class="bi bi-info-circle me-1"></i>
                            Maksimum 2MB boyutunda JPG veya PNG dosyası yükleyin.
                        </p>
                        <div style="
                            background: rgba(255,255,255,0.04);
                            border: 2px dashed rgba(255,255,255,0.15);
                            border-radius: 14px;
                            padding: 1.5rem;
                            text-align: center;
                            transition: all 0.3s;
                        " id="dropZone">
                            <i class="bi bi-cloud-upload" style="font-size:2rem;color:#6366f1;display:block;margin-bottom:0.75rem;"></i>
                            <label for="photoFile" style="cursor:pointer;color:#a5b4fc;font-weight:600;font-size:0.9rem;">
                                Dosya Seçmek İçin Tıkla
                            </label>
                            <input type="file" id="photoFile" name="photoFile" class="d-none" accept="image/*" required
                                   onchange="document.getElementById('fileNameDisplay').textContent = this.files[0]?.name ?? ''" />
                            <p class="text-muted small mt-2 mb-0" id="fileNameDisplay">veya sürükle & bırak</p>
                        </div>
                    </div>
                    <div class="modal-footer" style="border-top: 1px solid rgba(255,255,255,0.08); padding: 1rem 1.5rem; gap:0.75rem;">
                        <button type="button" class="glass-btn glass-btn-sm" data-bs-dismiss="modal">
                            <i class="bi bi-x-lg me-1"></i>İptal
                        </button>
                        <button type="submit" class="glass-btn glass-btn-sm glass-btn-success">
                            <i class="bi bi-cloud-upload-fill me-1"></i>Yükle ve Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
}
