@model IEnumerable<NoteTrackerApp.Models.Announcement>

@{
    ViewData["Title"] = "Duyuru Yönetimi";
    Layout = "_LayoutAdmin";
}

<style>
    .announcement-card {
        background: rgba(30, 41, 59, 0.45);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255, 255, 255, 0.08);
        border-radius: 16px;
        transition: all 0.3s ease;
        overflow: hidden;
    }
    .announcement-card:hover {
        transform: translateY(-4px);
        background: rgba(30, 41, 59, 0.6);
        border-color: rgba(99, 102, 241, 0.3);
        box-shadow: 0 12px 24px rgba(0, 0, 0, 0.3);
    }
    .line-clamp-3 {
        display: -webkit-box;
        -webkit-line-clamp: 3;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }
    .announcement-media-preview {
        height: 140px;
        width: 100%;
        object-fit: cover;
        border-radius: 12px;
        margin-bottom: 1rem;
        background: rgba(0,0,0,0.2);
    }
</style>

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="fw-bold m-0"><i class="bi bi-megaphone-fill text-primary me-2"></i>Duyuru Yönetimi</h4>
            <p class="text-muted small m-0">Tüm öğrencilere yönelik duyuruları buradan yönetebilirsiniz.</p>
        </div>
        <a asp-action="CreateAnnouncement" class="glass-btn">
            <i class="bi bi-plus-lg me-1"></i>Yeni Duyuru Yayınla
        </a>
    </div>

    <div class="row g-4">
        @if (!Model.Any())
        {
            <div class="col-12 text-center py-5">
                <i class="bi bi-bell-slash text-muted" style="font-size: 3rem;"></i>
                <p class="text-muted mt-3">Henüz hiçbir duyuru yayınlanmamış.</p>
            </div>
        }
        @foreach (var item in Model.OrderByDescending(a => a.CreatedAt))
        {
            <div class="col-xl-4 col-md-6">
                <div class="announcement-card p-3 h-100 d-flex flex-column">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                        @{
                            var bgClass = "rgba(148, 163, 184, 0.15)";
                            var textColor = "#94a3b8";
                            if (item.Category == "Sınav") { bgClass = "rgba(239, 68, 68, 0.15)"; textColor = "#fca5a5"; }
                            else if (item.Category == "Etkinlik") { bgClass = "rgba(16, 185, 129, 0.15)"; textColor = "#86efac"; }
                            else if (item.Category == "Uyarı") { bgClass = "rgba(245, 158, 11, 0.15)"; textColor = "#fcd34d"; }
                            else if (item.Category == "Genel") { bgClass = "rgba(99, 102, 241, 0.15)"; textColor = "#a5b4fc"; }
                        }
                        <span class="badge" style="background: @bgClass; color: @textColor; border: 1px solid rgba(255,255,255,0.05);">@item.Category</span>
                        <small class="text-muted">@item.CreatedAt.ToString("dd MMM yyyy")</small>
                    </div>

                    @if (!string.IsNullOrEmpty(item.MediaUrl) && item.MediaType == "image")
                    {
                        <img src="@item.MediaUrl" class="announcement-media-preview" alt="media" />
                    }

                    <h6 class="fw-bold mb-2">@item.Title</h6>
                    <p class="text-muted small line-clamp-3 mb-3 flex-grow-1" style="line-height: 1.5;">@item.Content</p>

                    <div class="d-flex justify-content-between align-items-center mt-auto pt-3 border-top border-secondary border-opacity-10">
                        <div class="d-flex gap-1">
                            <a href="#" class="badge-glass text-decoration-none" data-bs-toggle="modal" data-bs-target="#announcementModal-@item.Id">
                                <i class="bi bi-fullscreen me-1"></i>Detay
                            </a>
                            <a asp-action="AnnouncementViewers" asp-route-id="@item.Id" class="badge-glass text-decoration-none" style="background: rgba(56, 189, 248, 0.1); color: #7dd3fc;">
                                <i class="bi bi-eye me-1"></i>@(item.Views?.Count ?? 0)
                            </a>
                        </div>
                        <div class="d-flex gap-2">
                            <a asp-action="EditAnnouncement" asp-route-id="@item.Id" class="text-info" title="Düzenle">
                                <i class="bi bi-pencil-square fs-5"></i>
                            </a>
                            <a asp-action="DeleteAnnouncement" asp-route-id="@item.Id" class="text-danger" title="Sil" onclick="return confirm('Bu duyuruyu silmek istediğinize emin misiniz?');">
                                <i class="bi bi-trash3 fs-5"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Modal for Full Content -->
            <div class="modal fade modal-glass" id="announcementModal-@item.Id" tabindex="-1" aria-hidden="true">
                <div class="modal-dialog modal-dialog-centered modal-lg">
                    <div class="modal-content" style="background: rgba(15, 23, 42, 0.95); backdrop-filter: blur(24px); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px;">
                        <div class="modal-header border-bottom-0">
                            <span class="badge me-2" style="background: @bgClass; color: @textColor;">@item.Category</span>
                            <h5 class="modal-title fw-bold">@item.Title</h5>
                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            @if (!string.IsNullOrEmpty(item.MediaUrl))
                            {
                                <div class="text-center mb-4">
                                    @if (item.MediaType == "image")
                                    {
                                        <img src="@item.MediaUrl" class="img-fluid rounded-3 shadow" style="max-height: 450px; width: 100%; object-fit: contain; background: #000;" alt="media" />
                                    }
                                    else if (item.MediaType == "video")
                                    {
                                        <video src="@item.MediaUrl" controls class="w-100 rounded-3 shadow" style="max-height: 450px;"></video>
                                    }
                                </div>
                            }
                            <div class="px-2" style="white-space: pre-wrap; line-height: 1.7; color: rgba(255,255,255,0.9);">@item.Content</div>
                        </div>
                        <div class="modal-footer border-top-0 opacity-50 small">
                            Yayınlanma: @item.CreatedAt.ToString("f")
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>
