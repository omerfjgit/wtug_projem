@{
    ViewData["Title"] = "Gösterge Paneli";
    Layout = "_LayoutAdmin";
}

<div class="row g-4 mb-4">
    <div class="col-md-4">
        <div class="glass-card d-flex align-items-center">
            <div class="bg-primary bg-opacity-10 p-3 rounded-circle me-3">
                <i class="bi bi-people text-primary" style="font-size: 2rem;"></i>
            </div>
            <div>
                <h6 class="text-muted mb-1">Toplam Öğrenci</h6>
                <h3 class="fw-bold m-0">@ViewBag.StudentCount</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass-card d-flex align-items-center">
            <div class="bg-warning bg-opacity-10 p-3 rounded-circle me-3">
                <i class="bi bi-graph-up text-warning" style="font-size: 2rem;"></i>
            </div>
            <div>
                <h6 class="text-muted mb-1">Okul Ortalaması</h6>
                <h3 class="fw-bold m-0">@ViewBag.AverageGrade</h3>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="glass-card d-flex align-items-center">
            <div class="bg-info bg-opacity-10 p-3 rounded-circle me-3">
                <i class="bi bi-megaphone text-info" style="font-size: 2rem;"></i>
            </div>
            <div>
                <h6 class="text-muted mb-1">Duyurular</h6>
                <h3 class="fw-bold m-0">@ViewBag.AnnouncementsCount</h3>
            </div>
        </div>
    </div>
</div>

<div class="glass-card">
    <h5 class="fw-bold mb-3"><i class="bi bi-info-square"></i> Sisteme Hoş Geldiniz</h5>
    <p class="text-muted">Bu yönetici paneli üzerinden sol menüyü kullanarak öğrencileri kaydedebilir, kayıtlı öğrencilere açılır menüden not girebilir ve tüm okula duyurular yayınlayabilirsiniz.</p>
    <a asp-action="CreateStudent" class="btn btn-primary mt-2"><i class="bi bi-person-plus"></i> Yeni Öğrenci Ekle</a>
</div>

<div class="glass-card mt-4">
    <h5 class="fw-bold mb-4"><i class="bi bi-bar-chart-fill text-success"></i> Sınıf ve Ders Ortalamaları Analizi</h5>
    
    @if (ViewBag.ClassAverages != null)
    {
        var averages = ViewBag.ClassAverages as IEnumerable<dynamic>;
        if (averages != null && averages.Any())
        {
            <div class="table-responsive">
                <table class="table table-hover align-middle">
                    <thead style="background-color: var(--table-light-bg);">
                        <tr>
                            <th>Sınıf</th>
                            <th>Ders Adı</th>
                            <th>Ders Ortalaması</th>
                            <th>Durum</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in averages)
                        {
                            var avg = (decimal)item.Average;
                            <tr>
                                <td><span class="badge bg-primary">@item.ClassSection</span></td>
                                <td class="fw-bold">@item.CourseName</td>
                                <td class="fw-bold @(avg >= 50 ? "text-success" : "text-danger")">
                                    @avg.ToString("0.00")
                                </td>
                                <td>
                                    @if(avg >= 85) { <span class="badge bg-success">Çok İyi</span> }
                                    else if(avg >= 70) { <span class="badge bg-info text-dark">İyi</span> }
                                    else if(avg >= 50) { <span class="badge bg-warning text-dark">Orta</span> }
                                    else { <span class="badge bg-danger">Başarısız</span> }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted">Henüz not girişi yapılmamış.</p>
        }
    }
</div>
