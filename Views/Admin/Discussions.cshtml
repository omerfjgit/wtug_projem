@model IEnumerable<NoteTrackerApp.Models.Post>

@{
    ViewData["Title"] = "Sosyal Ağ Yönetimi";
    Layout = "_LayoutAdmin";
}

<div class="glass-card">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h5 class="m-0 fw-bold">Öğrenci Tartışmaları (Tüm Okul)</h5>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted py-4">Henüz hiç gönderi paylaşılmamış.</div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle" style="color: var(--text-color);">
                <thead style="background-color: var(--table-light-bg);">
                    <tr>
                        <th>Öğrenci</th>
                        <th>Hedef Kitle</th>
                        <th>Gönderi İçeriği</th>
                        <th>Tarih</th>
                        <th>Etkileşim</th>
                        <th>İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var post in Model)
                    {
                        <tr>
                            <td class="fw-bold">@post.User.FullName</td>
                            <td>
                                @if (string.IsNullOrEmpty(post.TargetClass))
                                {
                                    <span class="badge bg-primary">Tüm Okul</span>
                                }
                                else
                                {
                                    <span class="badge bg-info text-dark">@post.TargetClass</span>
                                }
                            </td>
                            <td style="max-width: 300px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                @post.Content
                            </td>
                            <td><small>@post.CreatedAt.ToString("dd MMM HH:mm")</small></td>
                            <td>
                                <span class="badge bg-secondary me-1"><i class="bi bi-chat"></i> @post.Comments.Count</span>
                                <span class="badge bg-secondary"><i class="bi bi-eye"></i> @post.Views.Count</span>
                            </td>
                            <td>
                                <form asp-action="DeletePost" method="post" onsubmit="return confirm('Bu gönderiyi silmek istediğinize emin misiniz? (Tüm yorumlar da silinecektir)');">
                                    <input type="hidden" name="id" value="@post.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger"><i class="bi bi-trash"></i> Sil</button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
