@model List<NoteTrackerApp.Models.Post>
@{
    ViewData["Title"] = "Tartışmalar";
    Layout = "_LayoutAdmin";
    var sort = ViewBag.Sort as string ?? "newest";
}

<div class="glass-card mb-3">
    <!-- Info uyarısı -->
    <div class="d-flex align-items-start gap-2 mb-4 p-3 rounded" style="background:rgba(56,189,248,0.08);border:1px solid rgba(56,189,248,0.2);">
        <i class="bi bi-info-circle-fill text-info fs-5 flex-shrink-0 mt-1"></i>
        <div style="font-size:0.85rem;">
            <strong class="d-block mb-1" style="color:#7dd3fc;">Moderasyon Paneli</strong>
            <span class="text-muted">Yönetici olarak tüm tartışmaları ve yorumları görüntüleyebilir, uygunsuz içerikleri kaldırabilirsiniz. Öğrenciler yalnızca kendi sınıflarına ait tartışmaları görebilir.</span>
        </div>
    </div>

    <!-- Yeni Gönderi Formu -->
    <form asp-action="CreatePost" method="post" enctype="multipart/form-data">
        <div class="d-flex gap-3">
            <div style="width:38px;height:38px;border-radius:50%;background:rgba(99,102,241,0.2);display:flex;align-items:center;justify-content:center;color:#6366f1;flex-shrink:0;">
                <i class="bi bi-shield-lock-fill"></i>
            </div>
            <div class="flex-grow-1">
                <textarea name="content" class="form-control mb-2" rows="2" placeholder="Okul geneli duyuru veya tartışma..."></textarea>
                <div class="d-flex gap-2 flex-wrap">
                    <select name="targetClass" class="form-select" style="max-width:180px;font-size:0.82rem;">
                        <option value="">Tüm Okul</option>
                        @foreach (var cls in new[]{"9-A","9-B","10-A","10-B","11-A","11-B","12-A","12-B"})
                        {
                            <option value="@cls">@cls</option>
                        }
                    </select>
                    <input type="file" name="mediaFile" class="form-control" style="max-width:200px;" />
                    <button type="submit" class="glass-btn glass-btn-sm">
                        <i class="bi bi-send-fill me-1"></i>Paylaş
                    </button>
                </div>
            </div>
        </div>
    </form>
</div>

<!-- Sıralama -->
<div class="d-flex gap-2 mb-3">
    <a asp-action="Discussions" asp-route-sort="newest" class="glass-btn glass-btn-sm @(sort == "newest" ? "glass-btn-success" : "")">
        <i class="bi bi-clock-fill me-1"></i>En Yeni
    </a>
    <a asp-action="Discussions" asp-route-sort="popular" class="glass-btn glass-btn-sm @(sort == "popular" ? "glass-btn-success" : "")">
        <i class="bi bi-fire me-1"></i>En Popüler
    </a>
</div>

@foreach (var post in Model)
{
    <div class="glass-card mb-3">
        <div class="d-flex align-items-start gap-3">
            @if (!string.IsNullOrEmpty(post.User.PhotoUrl))
            {
                <img src="@post.User.PhotoUrl" class="rounded-circle" width="40" height="40" style="object-fit:cover;flex-shrink:0;border:2px solid rgba(99,102,241,0.2);" />
            }
            else
            {
                <div style="width:40px;height:40px;border-radius:50%;background:rgba(99,102,241,0.1);display:flex;align-items:center;justify-content:center;color:#6366f1;flex-shrink:0;">
                    <i class="bi bi-person-fill"></i>
                </div>
            }
            <div class="flex-grow-1">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <span class="fw-semibold" style="font-size:0.9rem;">@post.User.FullName</span>
                        <span class="text-muted ms-2" style="font-size:0.75rem;">@post.CreatedAt.ToString("dd MMM HH:mm")</span>
                        @if (!string.IsNullOrEmpty(post.TargetClass))
                        { <span class="badge-glass ms-2">@post.TargetClass</span> }
                        else
                        { <span class="badge-glass ms-2" style="background:rgba(16,185,129,0.15);color:#86efac;border-color:rgba(16,185,129,0.25);">Tüm Okul</span> }
                    </div>
                    <div class="d-flex gap-2">
                        <a asp-action="PostDetails" asp-route-id="@post.Id" class="glass-btn glass-btn-sm">
                            <i class="bi bi-arrow-right-circle"></i>
                        </a>
                        <form asp-action="DeletePost" method="post">
                            <input type="hidden" name="id" value="@post.Id" />
                            <button type="submit" class="glass-btn glass-btn-sm glass-btn-danger"
                                    onclick="return confirm('Silmek istiyor musunuz?')"
                                    style="padding:0.3em 0.7em;">
                                <i class="bi bi-trash-fill"></i>
                            </button>
                        </form>
                    </div>
                </div>
                <p class="mt-2 mb-2" style="font-size:0.88rem;">@post.Content</p>
                @if (!string.IsNullOrEmpty(post.MediaUrl) && post.MediaType == "image")
                {
                    <img src="@post.MediaUrl" class="img-fluid rounded mb-2"
                         style="max-height:200px;object-fit:cover;cursor:zoom-in;border:1px solid rgba(255,255,255,0.07);"
                         onclick="document.getElementById('imgModal').style.display='flex';document.getElementById('imgModalSrc').src=this.src" />
                }
                <div class="d-flex gap-3" style="font-size:0.8rem;">
                    <span style="color:#86efac;"><i class="bi bi-hand-thumbs-up-fill me-1"></i>@post.Likes.Count(l => l.IsLike)</span>
                    <span style="color:#fca5a5;"><i class="bi bi-hand-thumbs-down-fill me-1"></i>@post.Likes.Count(l => !l.IsLike)</span>
                    <span class="text-muted"><i class="bi bi-chat-square me-1"></i>@post.Comments.Count</span>
                    <span class="text-muted"><i class="bi bi-eye me-1"></i>@post.Views.Count</span>
                </div>
            </div>
        </div>
    </div>
}

<!-- Image Modal -->
<div id="imgModal" onclick="this.style.display='none'"
     style="display:none;position:fixed;inset:0;background:rgba(0,0,0,0.92);z-index:9999;align-items:center;justify-content:center;cursor:zoom-out;">
    <img id="imgModalSrc" src="" style="max-width:95vw;max-height:95vh;border-radius:12px;" />
</div>

<style>
    .badge-glass { background:rgba(99,102,241,0.15);color:#a5b4fc;border:1px solid rgba(99,102,241,0.25);border-radius:6px;padding:2px 8px;font-size:0.72rem;font-weight:600; }
</style>
