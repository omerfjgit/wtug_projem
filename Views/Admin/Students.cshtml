@model List<NoteTrackerApp.Models.Student>
@{
    ViewData["Title"] = "Öğrenciler";
    Layout = "_LayoutAdmin";
    var search = ViewBag.Search as string ?? "";
}

<div class="glass-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h4 class="fw-bold m-0"><i class="bi bi-people-fill text-primary me-2"></i>Sistemde Kayıtlı Öğrenciler</h4>
            <small class="text-muted">Toplam @Model.Count öğrenci</small>
        </div>
        <div class="d-flex gap-2 flex-wrap">
            <form method="get" class="d-flex" style="min-width:260px;">
                <div class="input-group">
                    <input type="text" name="search" value="@search" class="form-control" placeholder="Ad, numara, sınıf..." style="border-radius: 10px 0 0 10px;" />
                    <button class="glass-btn glass-btn-sm" type="submit" style="border-radius: 0 10px 10px 0;"><i class="bi bi-search"></i></button>
                </div>
            </form>
            <a asp-action="CreateStudent" class="glass-btn">
                <i class="bi bi-person-plus-fill"></i> Yeni Öğrenci
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-person-x" style="font-size:3rem;color:#475569;"></i>
            <p class="text-muted mt-2">Arama kriteriyle eşleşen öğrenci bulunamadı.</p>
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead>
                    <tr>
                        <th>Fotoğraf</th>
                        <th>Öğrenci No</th>
                        <th>Ad Soyad</th>
                        <th>Kullanıcı Adı</th>
                        <th>Kurtarma Kodu</th>
                        <th>Yetki</th>
                        <th class="text-end">İşlemler</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(s.User.PhotoUrl))
                                {
                                    <img src="@s.User.PhotoUrl" class="rounded-circle" width="40" height="40" style="object-fit:cover;border:2px solid rgba(99,102,241,0.3);" />
                                }
                                else
                                {
                                    <div style="width:40px;height:40px;border-radius:50%;background:rgba(99,102,241,0.15);display:flex;align-items:center;justify-content:center;color:#6366f1;">
                                        <i class="bi bi-person-fill"></i>
                                    </div>
                                }
                            </td>
                            <td>
                                <span class="fw-bold">@s.StudentNumber</span>
                                <span class="badge-glass ms-1">@s.ClassSection</span>
                            </td>
                            <td class="fw-semibold">@s.User.FullName</td>
                            <td><code style="color:#94a3b8;font-size:0.82rem;">@s.User.Username</code></td>
                            <td>
                                @if (!string.IsNullOrEmpty(s.User.RecoveryPin))
                                {
                                    <span class="badge" style="background:rgba(99,102,241,0.15);color:#a5b4fc;border:1px solid rgba(99,102,241,0.3);font-family:monospace;font-size:0.85rem;letter-spacing:0.1em;padding:4px 10px;">
                                        @s.User.RecoveryPin
                                    </span>
                                }
                                else
                                {
                                    <span class="text-muted small">—</span>
                                }
                            </td>
                            <td>
                                @if (s.User.CanChangePhoto)
                                {
                                    <span class="badge" style="background:rgba(16,185,129,0.15);color:#86efac;border:1px solid rgba(16,185,129,0.3);">Açık</span>
                                }
                                else
                                {
                                    <span class="badge" style="background:rgba(239,68,68,0.15);color:#fca5a5;border:1px solid rgba(239,68,68,0.3);">Kısıtlı</span>
                                }
                            </td>
                            <td class="text-end">
                                <div class="d-flex gap-2 justify-content-end">
                                    <a asp-action="EditStudent" asp-route-id="@s.Id" class="glass-btn glass-btn-sm glass-btn-info">
                                        <i class="bi bi-pencil-fill"></i>
                                    </a>
                                    <a asp-action="DeleteStudent" asp-route-id="@s.Id" class="glass-btn glass-btn-sm glass-btn-danger"
                                       onclick="return confirm('Bu öğrenciyi silmek istediğinize emin misiniz?')">
                                        <i class="bi bi-trash-fill"></i>
                                    </a>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
