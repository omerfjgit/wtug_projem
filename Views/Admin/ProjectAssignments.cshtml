@model List<NoteTrackerApp.Models.ProjectAssignment>
@{
    ViewData["Title"] = "Proje Ödevleri";
    Layout = "_LayoutAdmin";
    var students = ViewBag.Students as List<NoteTrackerApp.Models.Student>;
    var search = ViewBag.Search as string ?? "";
}

<div class="glass-card mb-4">
    <button class="glass-btn glass-btn-sm mb-3" type="button" data-bs-toggle="collapse" data-bs-target="#addProjectForm">
        <i class="bi bi-folder-plus me-1"></i>Yeni Proje Ödevi Oluştur
    </button>

    <div class="collapse" id="addProjectForm">
        <form asp-action="CreateProjectAssignment" method="post">
            <div class="row g-3">
                <div class="col-md-4">
                    <label class="form-label">Öğrenci</label>
                    <select name="StudentId" class="form-select" required>
                        <option value="">Öğrenci Seç...</option>
                        @foreach (var s in students ?? new())
                        {
                            <option value="@s.Id">@s.User.FullName (@s.ClassSection)</option>
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Ders</label>
                    <input type="text" name="CourseName" class="form-control" placeholder="Bilgisayar, Türkçe..." required />
                </div>
                <div class="col-md-5">
                    <label class="form-label">Proje Konusu</label>
                    <input type="text" name="Topic" class="form-control" placeholder="Konu başlığı..." required />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Taslak Teslim Tarihi</label>
                    <input type="date" name="DraftDueDate" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Ara Kontrol Tarihi</label>
                    <input type="date" name="CheckDate" class="form-control" />
                </div>
                <div class="col-md-4">
                    <label class="form-label">Nihai Teslim Tarihi</label>
                    <input type="date" name="FinalDueDate" class="form-control" />
                </div>
                <div class="col-12">
                    <button type="submit" class="glass-btn"><i class="bi bi-check-lg me-1"></i>Oluştur</button>
                </div>
            </div>
        </form>
    </div>
</div>

<div class="glass-card">
    <div class="d-flex flex-wrap justify-content-between align-items-center mb-4 gap-3">
        <div>
            <h4 class="fw-bold m-0"><i class="bi bi-folder2-open text-primary me-2"></i>Proje Ödevleri</h4>
            <small class="text-muted">@Model.Count proje kaydı</small>
        </div>
        <form method="get" class="d-flex" style="min-width:240px;">
            <div class="input-group">
                <span class="input-group-text" style="background:rgba(30,41,59,0.5);border-color:rgba(255,255,255,0.1);color:#6366f1;">
                    <i class="bi bi-search"></i>
                </span>
                <input type="text" name="search" value="@search" class="form-control" placeholder="Öğrenci, konu..." />
                <button class="glass-btn glass-btn-sm" type="submit"><i class="bi bi-search"></i></button>
            </div>
        </form>
    </div>

    @foreach (var p in Model)
    {
        <div class="glass-panel mb-3">
            <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
                <div>
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="fw-bold">@p.Student.User.FullName</span>
                        <span class="badge-glass">@p.Student.ClassSection</span>
                        <span class="badge-glass" style="background:rgba(56,189,248,0.12);color:#7dd3fc;border-color:rgba(56,189,248,0.25);">@p.CourseName</span>
                    </div>
                    <div class="fw-semibold mb-1" style="color:#c7d2fe;">@p.Topic</div>
                    <div class="d-flex gap-3 flex-wrap" style="font-size:0.78rem;color:#64748b;">
                        @if (p.DraftDueDate.HasValue)
                        { <span><i class="bi bi-file-earmark-text me-1"></i>Taslak: @p.DraftDueDate.Value.ToString("dd MMM")</span> }
                        @if (p.CheckDate.HasValue)
                        { <span><i class="bi bi-eye me-1"></i>Kontrol: @p.CheckDate.Value.ToString("dd MMM")</span> }
                        @if (p.FinalDueDate.HasValue)
                        { <span><i class="bi bi-calendar-check me-1"></i>Nihai: @p.FinalDueDate.Value.ToString("dd MMM")</span> }
                    </div>
                </div>
                <div class="d-flex align-items-center gap-2 flex-wrap">
                    @{
                        var statusColors = new Dictionary<NoteTrackerApp.Models.ProjectStatus, string>
                        {
                            [NoteTrackerApp.Models.ProjectStatus.Atandı]    = "#94a3b8",
                            [NoteTrackerApp.Models.ProjectStatus.Taslak]    = "#fbbf24",
                            [NoteTrackerApp.Models.ProjectStatus.AraKontrol]= "#38bdf8",
                            [NoteTrackerApp.Models.ProjectStatus.NihaiFazı] = "#a78bfa",
                            [NoteTrackerApp.Models.ProjectStatus.Teslim]    = "#86efac",
                        };
                        var statusNames = new Dictionary<NoteTrackerApp.Models.ProjectStatus, string>
                        {
                            [NoteTrackerApp.Models.ProjectStatus.Atandı]    = "Atandı",
                            [NoteTrackerApp.Models.ProjectStatus.Taslak]    = "Taslak Aşaması",
                            [NoteTrackerApp.Models.ProjectStatus.AraKontrol]= "Ara Kontrol",
                            [NoteTrackerApp.Models.ProjectStatus.NihaiFazı] = "Nihai Faz",
                            [NoteTrackerApp.Models.ProjectStatus.Teslim]    = "Teslim Edildi",
                        };
                    }
                    <span style="font-weight:700;color:@statusColors[p.Status];font-size:0.82rem;">● @statusNames[p.Status]</span>

                    <!-- Durum Güncelleme -->
                    <form asp-action="UpdateProjectStatus" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@p.Id" />
                        <select name="status" class="form-select" style="max-width:160px;font-size:0.78rem;"
                                onchange="this.form.submit()">
                            @foreach (NoteTrackerApp.Models.ProjectStatus s in Enum.GetValues(typeof(NoteTrackerApp.Models.ProjectStatus)))
                            {
                                if (p.Status == s)
                                {
                                    <option value="@((int)s)" selected>@statusNames[s]</option>
                                }
                                else
                                {
                                    <option value="@((int)s)">@statusNames[s]</option>
                                }
                            }
                        </select>
                    </form>

                    <form asp-action="DeleteProjectAssignment" method="post" class="d-inline">
                        <input type="hidden" name="id" value="@p.Id" />
                        <button type="submit" class="glass-btn glass-btn-sm glass-btn-danger"
                                onclick="return confirm('Projeyi silmek istiyor musunuz?')">
                            <i class="bi bi-trash-fill"></i>
                        </button>
                    </form>
                </div>
            </div>
            @if (!string.IsNullOrEmpty(p.TeacherNote))
            {
                <div class="mt-2 p-2 rounded" style="background:rgba(99,102,241,0.07);border-left:3px solid #6366f1;font-size:0.82rem;color:#94a3b8;">
                    <i class="bi bi-chat-quote me-1"></i>@p.TeacherNote
                </div>
            }
        </div>
    }

    @if (!Model.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-folder-x" style="font-size:3rem;color:#475569;"></i>
            <p class="text-muted mt-2">Henüz proje ödevi oluşturulmamış.</p>
        </div>
    }
</div>

<style>
    .badge-glass { background:rgba(99,102,241,0.15);color:#a5b4fc;border:1px solid rgba(99,102,241,0.25);border-radius:6px;padding:2px 8px;font-size:0.72rem;font-weight:600; }
</style>
