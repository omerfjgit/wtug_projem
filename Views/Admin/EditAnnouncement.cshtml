@model NoteTrackerApp.Models.Announcement
@{
    ViewData["Title"] = "Duyuruyu Düzenle";
    Layout = "_LayoutAdmin";
}

<div class="glass-card" style="max-width:700px;margin:0 auto;">
    <h4 class="fw-bold mb-4"><i class="bi bi-pencil-square text-primary me-2"></i>Duyuruyu Düzenle</h4>

    <form asp-action="EditAnnouncement" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="Id" />

        <div class="mb-3">
            <label class="form-label">Kategori</label>
            <select asp-for="Category" class="form-select">
                <option value="Genel">Genel</option>
                <option value="Sınav">Sınav</option>
                <option value="Etkinlik">Etkinlik</option>
                <option value="Uyarı">Uyarı</option>
                <option value="Duyuru">Duyuru</option>
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Başlık</label>
            <input asp-for="Title" class="form-control" placeholder="Duyuru başlığı..." />
        </div>

        <div class="mb-3">
            <label class="form-label">İçerik</label>
            <textarea asp-for="Content" class="form-control" rows="5" placeholder="Duyuru içeriği..."></textarea>
        </div>

        <!-- Mevcut Medya -->
        @if (!string.IsNullOrEmpty(Model.MediaUrl))
        {
            <div class="mb-3 glass-panel">
                <label class="form-label">Mevcut Medya</label>
                <div class="d-flex align-items-center gap-3">
                    @if (Model.MediaType == "image")
                    {
                        <img src="@Model.MediaUrl" alt="Mevcut resim" class="rounded"
                             style="max-height:120px;max-width:200px;object-fit:cover;border:1px solid rgba(255,255,255,0.1);" />
                    }
                    else
                    {
                        <div class="d-flex align-items-center gap-2" style="color:#94a3b8;">
                            <i class="bi bi-file-earmark fs-4"></i>
                            <span>@Model.MediaUrl</span>
                        </div>
                    }
                    <div>
                        <div class="form-check">
                            <input class="form-check-input" type="checkbox" name="removeMedia" id="removeMedia" value="true" />
                            <label class="form-check-label text-danger" for="removeMedia">
                                <i class="bi bi-trash me-1"></i>Bu medyayı kaldır
                            </label>
                        </div>
                    </div>
                </div>
            </div>
        }

        <!-- Yeni Medya -->
        <div class="mb-4">
            <label class="form-label">
                @(string.IsNullOrEmpty(Model.MediaUrl) ? "Medya Ekle (İsteğe Bağlı)" : "Yeni Medya Yükle (Mevcut'un üzerine yazar)")
            </label>
            <input type="file" name="mediaFile" class="form-control" accept="image/*,video/*,.pdf,.doc,.docx" />
            <small class="text-muted">Resim, video veya dosya yükleyebilirsiniz.</small>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="glass-btn">
                <i class="bi bi-check-lg me-1"></i>Değişiklikleri Kaydet
            </button>
            <a asp-action="Announcements" class="glass-btn">
                <i class="bi bi-arrow-left me-1"></i>Geri
            </a>
        </div>
    </form>
</div>
