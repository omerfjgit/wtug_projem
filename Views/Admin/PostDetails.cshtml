@model NoteTrackerApp.Models.Post

@{
    ViewData["Title"] = "Gönderi Detayı";
    Layout = "_LayoutAdmin";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        <!-- Orijinal Gönderi -->
        <div class="glass-card mb-4" style="border-left: 4px solid #38bdf8;">
            <div class="d-flex align-items-start mb-3">
                @if (string.IsNullOrEmpty(Model.User.PhotoUrl))
                {
                    <div style="width: 56px; height: 56px; border-radius: 50%; background: var(--primary-gradient); display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; font-size: 1.5rem;" class="me-3">
                        @Model.User.FullName.Substring(0, 1).ToUpper()
                    </div>
                }
                else
                {
                    <img src="@Model.User.PhotoUrl" alt="Profil" style="width: 56px; height: 56px; border-radius: 50%; object-fit: cover;" class="me-3" />
                }
                <div>
                    <h5 class="fw-bold m-0" style="color: var(--text-color);">
                        @Model.User.FullName
                        @if(Model.User.Role == "Admin") { <i class="bi bi-patch-check-fill text-primary ms-1 small"></i> }
                    </h5>
                    <small class="text-muted">
                        @(string.IsNullOrEmpty(Model.TargetClass) ? "Tüm Okul" : $"{Model.TargetClass} Sınıfı") • @Model.CreatedAt.ToString("dd MMM yyyy HH:mm")
                    </small>
                </div>
            </div>
            
            <p class="fs-5 mb-3" style="color: var(--text-color);">@Model.Content</p>
            
            @if (!string.IsNullOrEmpty(Model.MediaUrl))
            {
                <div class="mb-3">
                    @if (Model.MediaType == "image") { <img src="@Model.MediaUrl" class="img-fluid rounded" style="max-height:400px; object-fit:cover; width:100%;" /> }
                    else if (Model.MediaType == "video") { <video src="@Model.MediaUrl" controls class="w-100 rounded" style="max-height:400px;"></video> }
                    else { <a href="@Model.MediaUrl" target="_blank" class="btn btn-sm btn-outline-info"><i class="bi bi-file-earmark me-1"></i> Eki İndir</a> }
                </div>
            }
            
            <div class="d-flex gap-4 border-top pt-3" style="border-color: var(--card-border) !important; opacity: 0.8;">
                <span class="text-muted small fw-bold"><i class="bi bi-chat-left-text me-1"></i> @Model.Comments.Count Yorum</span>
                @{ var uvc = Model.Views.Select(v => v.UserId).Distinct().Count(); }
                <span class="text-muted small fw-bold"><i class="bi bi-eye me-1"></i> @uvc Görüntülenme</span>
            </div>
        </div>

        <!-- Yorum Ekleme -->
        <div class="glass-card mb-4">
            <form asp-action="AddComment" method="post" enctype="multipart/form-data">
                <input type="hidden" name="postId" value="@Model.Id" />
                <div class="mb-2">
                    <textarea name="content" class="form-control" rows="2" placeholder="Yanıtınızı yazın..." required style="resize: none;"></textarea>
                </div>
                <div class="d-flex gap-2 align-items-center justify-content-between">
                    <label class="d-flex align-items-center gap-2 text-muted small" style="cursor:pointer;">
                        <i class="bi bi-paperclip fs-5"></i>
                        <input type="file" name="mediaFile" class="d-none" />
                        <span>Medya Ekle</span>
                    </label>
                    <button type="submit" class="glass-btn">Yanıtla <i class="bi bi-send ms-1"></i></button>
                </div>
            </form>
        </div>

        <h6 class="fw-bold mb-3 ms-2 text-muted">Yorumlar (@Model.Comments.Count)</h6>
        
        @foreach (var comment in Model.Comments.OrderBy(c => c.CreatedAt))
        {
            <div class="glass-card mb-3 p-3">
                <div class="d-flex gap-3">
                    @if (string.IsNullOrEmpty(comment.User.PhotoUrl))
                    {
                        <div style="width: 40px; height: 40px; border-radius: 50%; background: #64748b; display: flex; align-items: center; justify-content: center; color: white; font-weight: bold; flex-shrink: 0;">
                            @comment.User.FullName.Substring(0, 1).ToUpper()
                        </div>
                    }
                    else
                    {
                        <img src="@comment.User.PhotoUrl" style="width: 40px; height: 40px; border-radius: 50%; object-fit: cover; flex-shrink: 0;" />
                    }
                    <div class="flex-grow-1">
                        <div class="d-flex justify-content-between align-items-center mb-1">
                            <span class="fw-bold" style="color: var(--text-color);">
                                @comment.User.FullName
                                @if(comment.User.Role == "Admin") { <i class="bi bi-patch-check-fill text-primary ms-1 small"></i> }
                            </span>
                            <small class="text-muted">@comment.CreatedAt.ToString("HH:mm - dd MMM")</small>
                        </div>
                        <p class="m-0 small" style="color: var(--text-color); opacity: 0.9;">@comment.Content</p>
                        @if (!string.IsNullOrEmpty(comment.MediaUrl))
                        {
                            <div class="mt-2">
                                @if (comment.MediaType == "image") { <img src="@comment.MediaUrl" class="img-fluid rounded" style="max-height:200px;" /> }
                                else if (comment.MediaType == "video") { <video src="@comment.MediaUrl" controls class="w-100 rounded" style="max-height:200px;"></video> }
                                else { <a href="@comment.MediaUrl" target="_blank" class="btn btn-sm btn-outline-secondary mt-1"><i class="bi bi-file-earmark me-1"></i> Dosya</a> }
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'));
        tooltipTriggerList.map(el => new bootstrap.Tooltip(el));
    </script>
}
