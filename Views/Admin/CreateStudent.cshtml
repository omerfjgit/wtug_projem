@{
    ViewData["Title"] = "Öğrenci Oluştur";
    Layout = "_LayoutAdmin";
}

<div class="row">
    <div class="col-md-8 mx-auto">
        <div class="glass-card">
            <h5 class="mb-4 fw-bold"><i class="bi bi-person-plus text-primary"></i> Yeni Öğrenci Kaydı</h5>
            
            <div class="alert alert-info py-2">
                <i class="bi bi-info-circle"></i> Burada oluşturduğunuz kullanıcı adı ve şifre ile öğrenci sisteme giriş yapabilecektir.
            </div>

            <form asp-action="CreateStudent" method="post">
                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Öğrenci No</label>
                        <input type="text" name="studentNumber" class="form-control" placeholder="Örn: 1054" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Sınıf / Şube</label>
                        <input type="text" name="classSection" class="form-control" placeholder="Örn: 11/A" required />
                    </div>
                    <div class="col-12">
                        <label class="form-label text-muted small fw-bold">Öğrencinin Adı Soyadı</label>
                        <input type="text" name="fullName" class="form-control" placeholder="Örn: Ahmet Yılmaz" required />
                    </div>
                    
                    <hr class="my-4 text-muted" />
                    <h6 class="fw-bold">Giriş Bilgileri</h6>

                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Sistem Kullanıcı Adı</label>
                        <input type="text" name="username" class="form-control" placeholder="Örn: ahmet1054" required />
                    </div>
                    <div class="col-md-6">
                        <label class="form-label text-muted small fw-bold">Sistem Şifresi</label>
                        <input type="password" name="password" class="form-control" placeholder="Öğrencinin giriş yapacağı şifre" required />
                    </div>
                    
                    <div class="col-12 mt-4 text-end">
                        <a asp-action="Students" class="btn btn-outline-secondary me-2">İptal</a>
                        <button type="submit" class="btn btn-primary"><i class="bi bi-check-lg"></i> Öğrenciyi Kaydet</button>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>
