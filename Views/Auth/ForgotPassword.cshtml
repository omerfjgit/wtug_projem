@{
    ViewData["Title"] = "Şifremi Unuttum";
    Layout = "_LayoutAuth";
}

<div class="text-center mb-4">
    <i class="bi bi-shield-lock" style="font-size: 3rem; color: #f59e0b;"></i>
    <h3 class="fw-bold mt-2">Şifre Sıfırlama</h3>
    <p class="text-light opacity-75 small">Öğretmeninizden aldığınız 6 haneli Kurtarma Kodu ile şifrenizi yenileyin.</p>
</div>

@if (ViewBag.Error != null)
{
    <div class="alert alert-danger bg-danger text-white border-0 py-2">
        <i class="bi bi-exclamation-circle"></i> @ViewBag.Error
    </div>
}

<form asp-action="ForgotPassword" method="post">
    <div class="mb-3">
        <label for="username" class="form-label text-light opacity-75 small">Kullanıcı Adı</label>
        <input type="text" class="form-control" id="username" name="username" placeholder="Sistem kullanıcı adınız" required>
    </div>
    
    <div class="mb-3">
        <label for="recoveryPin" class="form-label text-light opacity-75 small">Kurtarma Kodu (PIN)</label>
        <input type="text" class="form-control border-warning" id="recoveryPin" name="recoveryPin" placeholder="Örn: A7B9X2" required>
    </div>

    <div class="mb-4">
        <label for="newPassword" class="form-label text-light opacity-75 small">Yeni Şifre</label>
        <input type="password" class="form-control" id="newPassword" name="newPassword" placeholder="Yeni şifrenizi belirleyin" required>
    </div>

    <button type="submit" class="btn w-100 fw-bold py-2 mb-3" style="background: linear-gradient(135deg, #d97706, #f59e0b); color: white; border: none; box-shadow: 0 4px 15px rgba(245, 158, 11, 0.4);">
        Şifremi Güncelle <i class="bi bi-check2-circle ms-1"></i>
    </button>
    
    <div class="text-center">
        <a asp-action="Login" class="text-info text-decoration-none small"><i class="bi bi-arrow-left"></i> Giriş Ekranına Dön</a>
    </div>
</form>
